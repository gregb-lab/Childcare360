# ─── LittleSteps Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values

# Server
PORT=3003
NODE_ENV=production

# JWT Secret — CHANGE THIS IN PRODUCTION (use: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Google OAuth (optional — get from https://console.cloud.google.com)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple OAuth (optional — get from https://developer.apple.com)
# APPLE_CLIENT_ID=com.your.app.identifier

# Email / SMTP (optional — for sending verification codes)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password-here
# SMTP_FROM=noreply@littlesteps.com.au
